# Database Configuration
# PostgreSQL connection string for the application's own database
DATABASE_URL="postgresql://username:password@localhost:5432/talk2db"

# NextAuth Configuration
# Secret key for JWT token signing (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-here"

# Hugging Face Gradio Space Configuration
# Gradio space name for the fine-tuned SQL model
GRADIO_SPACE="saadkhi/SQL_chatbot_API"

# Hugging Face API Token (optional, required for private spaces)
HF_TOKEN="hf_your-huggingface-token-here"

# OpenRouter API Configuration
# OpenRouter API key for LLM fallback
OPENROUTER_API_KEY="sk-or-your-openrouter-api-key-here"

# OpenRouter base URL (optional, defaults to https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# OpenRouter model to use (optional, defaults to baidu/cobuddy:free)
OPENROUTER_MODEL="baidu/cobuddy:free"

# Database Encryption Key
# 32-byte hex string for encrypting user database connection strings
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"

# Node Environment
NODE_ENV="development"
